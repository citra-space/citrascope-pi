{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build Image (main)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Build Image (custom ref)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/build.py",
            "args": ["--citrasense-ref", "${input:citrasense_ref}"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ],
    "inputs": [
        {
            "id": "citrasense_ref",
            "type": "promptString",
            "description": "Git branch, tag, or commit SHA",
            "default": "main"
        }
    ]
}
